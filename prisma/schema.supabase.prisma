// Schema para Supabase (PostgreSQL) — produção
// Use com: npx prisma generate --schema=prisma/schema.supabase.prisma
//           npx prisma db push --schema=prisma/schema.supabase.prisma

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma-pg"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  // Identificadores
  id             Int             @id @default(autoincrement())
  authId         String          @unique
  email          String          @unique

  // Dados do Usuário
  fullName       String?
  displayName    String?
  avatarUrl      String?
  passwordHash   String?
  bio            String?
  favoriteGenres String?
  role           String          @default("client")

  // Datas / Timestamps
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relacionamentos
  preferences    Preference?
  watchHistory   WatchHistory[]
  watchlist      WatchlistItem[]
  ratings        Rating[]

  @@map("profiles")
}

model Preference {
  // Chaves Primária e Estrangeira
  id                       Int       @id @default(autoincrement())
  profileId                Int       @unique

  // Configurações de Preferência
  avatarIndex              Int       @default(0)
  genres                   String
  recommendationsUpdatedAt DateTime?

  // Datas / Timestamps
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Relacionamentos
  profile                  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

model WatchlistItem {
  // Chaves Primária e Estrangeira
  id          Int      @id @default(autoincrement())
  profileId   Int
  tmdbId      Int
  mediaType   String

  // Informações do Conteúdo
  title       String
  posterUrl   String?
  backdropUrl String?

  // Datas / Timestamps
  addedAt     DateTime @default(now())

  // Relacionamentos
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, tmdbId, mediaType])
  @@map("watchlist")
}

model WatchHistory {
  // Chaves Primária e Estrangeira
  id              Int      @id @default(autoincrement())
  profileId       Int
  tmdbId          Int
  mediaType       String

  // Informações do Conteúdo
  title           String
  posterUrl       String?
  backdropUrl     String?

  // Rastreamento de Progresso e Episódios
  seasonNumber    Int      @default(0)
  episodeNumber   Int      @default(0)
  totalSeasons    Int      @default(0)
  totalEpisodes   Int      @default(0)
  progressPercent Float    @default(0)

  // Datas / Timestamps
  watchedAt       DateTime @default(now())

  // Relacionamentos
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, tmdbId, mediaType])
  @@map("watch_history")
}

model Rating {
  // Chaves Primária e Estrangeira
  id        Int      @id @default(autoincrement())
  profileId Int
  tmdbId    Int
  mediaType String

  // Dados da Avaliação
  value     String

  // Datas / Timestamps
  createdAt DateTime @default(now())

  // Relacionamentos
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, tmdbId, mediaType])
  @@map("ratings")
}

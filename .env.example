# ============================================================
# TMDB API Configuration
# ============================================================
# Get your API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================================
# DATABASE — Escolha o provider conforme o ambiente
# ============================================================
# Para desenvolvimento local (SQLite):
DATABASE_URL="file:./dev.db"
#
# Para produção com Supabase (PostgreSQL):
# DATABASE_URL="postgresql://postgres.[REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres"
#
# DIRECT_URL é obrigatória para Prisma db push/migrate (conexão direta, porta 5432, sem pooler):
# DIRECT_URL="postgresql://postgres.[REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"
#
# lib/prisma.ts detecta automaticamente:
#   - "file:"     → SQLite (better-sqlite3)
#   - "postgres"  → PostgreSQL (Supabase)

# ============================================================
# SUPABASE (opcional — para futuras integrações de Auth/Storage)
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
